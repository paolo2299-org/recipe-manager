ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: send traces to Honeycomb. Set to your Honeycomb ingest API key.
HONEYCOMB_API_KEY=
# Optional: override the OTel service name (default: recipe-manager).
# OTEL_SERVICE_NAME=recipe-manager
SECRET_KEY=change-me-in-production
FLASK_ENV=development
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-in-production
# Optional: override the SQLite DB location.
# Defaults to /app/data/recipes.db inside the container (set in the Dockerfile).
# DATABASE_PATH=/app/data/recipes.db

# On Railway you don't need this file: set ANTHROPIC_API_KEY, SECRET_KEY,
# AUTH_USERNAME and AUTH_PASSWORD as service variables, mount a volume at
# /app/data, and leave PORT unset (Railway injects it). See docs/self-hosting.md
# and docs/railway-template.md.
